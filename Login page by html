<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login Page by Vansh</title>
    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: linear-gradient(135deg, #8e2de2 0%, #4a00e0 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .login-box {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.2);
            width: 350px;
            text-align: center;
        }

        h2 {
            color: #4a00e0;
            margin-bottom: 5px;
        }

        .subtitle {
            color: #777;
            font-size: 14px;
            margin-bottom: 30px;
        }

        .input-group {
            text-align: left;
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-weight: bold;
            margin-bottom: 8px;
            color: #333;
        }

        input {
            width: 100%;
            padding: 12px;
            border: 2px solid #eee;
            border-radius: 10px;
            box-sizing: border-box;
        }

        input:focus {
            border-color: #8e2de2;
            outline: none;
        }

        button {
            width: 100%;
            padding: 12px;
            background: #4a00e0;
            color: white;
            border: none;
            border-radius: 10px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }

        button:hover {
            background: #8e2de2;
            transform: scale(1.03);
        }

        .footer-text {
            margin-top: 20px;
            font-size: 13px;
            color: #666;
        }

        a {
            color: #4a00e0;
            text-decoration: none;
            font-weight: bold;
        }
    </style>
</head>
<body>

<div class="login-box">
    <h2>Welcome to Login Page</h2>
    <p class="subtitle">by Vansh</p>

    <form>
        <div class="input-group">
            <label>Email or User ID</label>
            <input type="text" placeholder="abxy@gmail.com" required>
        </div>

        <div class="input-group">
            <label>Password</label>
            <input type="password" placeholder="••••••••" required>
        </div>

        <button type="submit">Sign In</button>
    </form>

    <p class="footer-text">Don't have an account? <a href="#">Register here</a></p>
</div>

</body>
</html>
